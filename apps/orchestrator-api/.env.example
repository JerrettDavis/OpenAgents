# Copy this to .env and fill in your credentials.
# .env is gitignored — never commit real keys.

# Required for Claude Code / AC Claude providers
ANTHROPIC_API_KEY=

# Required for Codex / AC Codex providers
OPENAI_API_KEY=

# Required for Copilot / AC Copilot providers (one of these)
GH_TOKEN=
GITHUB_TOKEN=

# Required for Gemini providers
GEMINI_API_KEY=
