{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.AspNetCore.SpaProxy": "Information"
    }
  },
  "ConnectionStrings": {
    "OpenAgents": "Data Source=./openagents-local.db"
  },
  "OpenAgents": {
    "Docker": {
      "SocketPath": "/var/run/docker.sock"
    },
    "AgentContainers": {
      "Enabled": true,
      "Mode": "local",
      "LocalRepoPath": "C:/git/AgentContainers",
      "LoadEnvMetadataFromDefinitions": true,
      "ProviderIdPrefix": "ac-"
    },
    "Storage": {
      "WorkspaceBasePath": "./local-workspaces",
      "ArtifactsBasePath": "./local-artifacts"
    },
    "Paths": {
      "WorkflowsDir": "../../workflows",
      "ProvidersDir": "../../providers"
    },
    "UseLocalSimRuntime": false,
    "SpaProxy": false
  }
}
