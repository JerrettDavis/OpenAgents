# ============================================================================
# OpenAgents .gitignore
# Conservative but comprehensive coverage for:
#   - ASP.NET Core (.NET / C#)
#   - Node.js / React / Next.js
#   - Docker / containers
#   - Development tools
#   - OS-specific files
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────
# .NET / ASP.NET Core
# ─────────────────────────────────────────────────────────────────────────

# Build outputs
bin/
obj/
out/
.vs/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio cache/options directory
.vs/

# Local test runner
.vscode/

# NuGet lock files (legacy packages.config restore — NOT the monorepo packages/ dir)
# Scoped to prevent colliding with the monorepo's packages/ workspace directory.
**/packages/repositories.config
# If you see a packages/ dir created at the solution root by old-style NuGet restore, ignore it:
# packages/
# !packages/repositories.config
*.nupkg
*.snupkg

# Entity Framework
*.db
*.db-shm
*.db-wal
*.mdf
*.ldf

# Build results
*.plg
*.opt

# ─────────────────────────────────────────────────────────────────────────
# Node.js / npm / yarn / pnpm
# ─────────────────────────────────────────────────────────────────────────

node_modules/
npm-debug.log
npm-debug.log.*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Package manager lock files — commit pnpm-lock.yaml for reproducibility
# package-lock.json and yarn.lock are excluded (we use pnpm)
package-lock.json
yarn.lock
# pnpm-lock.yaml  ← intentionally tracked; remove this line to commit it

# Production build outputs
dist/
build/
.next/
out/

# Next.js specific
.env.local
.env.*.local
.cache/
.swc/

# Testing
coverage/
.nyc_output/
playwright-report/
test-results/
TestResults/

# ─────────────────────────────────────────────────────────────────────────
# Docker
# ─────────────────────────────────────────────────────────────────────────

# Build artifacts
docker-compose.override.yml

# ─────────────────────────────────────────────────────────────────────────
# IDEs & Editors
# ─────────────────────────────────────────────────────────────────────────

# VS Code
.vscode/
*.code-workspace
.history/

# JetBrains IDEs (IntelliJ, Rider, etc.)
.idea/
*.iml
*.iws
*.ipr
out/

# Sublime Text
*.sublime-workspace
*.sublime-project

# Vim
*.swp
*.swo
*~
.vim/

# Emacs
*~
\#*\#
.\#*

# ─────────────────────────────────────────────────────────────────────────
# OS-Specific Files
# ─────────────────────────────────────────────────────────────────────────

# Windows
Thumbs.db
Desktop.ini
.DS_Store
ehthumbs.db

# macOS
.DS_Store
.AppleDouble
.LSOverride
*.swp

# Linux
.directory

# ─────────────────────────────────────────────────────────────────────────
# Environment & Secrets
# ─────────────────────────────────────────────────────────────────────────

# Environment files (NEVER commit secrets)
.env
.env.*.local
.env.production.local
.env.development.local
.env.test.local

# AWS / Cloud credentials
.aws/
.azure/
.gcloud/

# SSH keys and credentials
id_rsa
id_rsa.pub
id_dsa
*.pem
*.key
*.crt

# ─────────────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────────────

logs/
*.log
*.log.*
lerna-debug.log*

# ─────────────────────────────────────────────────────────────────────────
# Database & Temporary Files
# ─────────────────────────────────────────────────────────────────────────

*.db
*.sqlite
*.sqlite3
*.pgdump
*.sql.gz

# Temporary files
*.tmp
*.temp
*.bak
*.backup
*.swp

# ─────────────────────────────────────────────────────────────────────────
# Build Artifacts & Generated Files
# ─────────────────────────────────────────────────────────────────────────

# TypeScript
*.tsbuildinfo
dist/
*.d.ts

# Bundlers
.parcel-cache
.cache
dist/

# ─────────────────────────────────────────────────────────────────────────
# Runtime & Development Artifacts
# ─────────────────────────────────────────────────────────────────────────

# Pytest / test output
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
.coverage.*

# ─────────────────────────────────────────────────────────────────────────
# OpenAgents Specific
# ─────────────────────────────────────────────────────────────────────────

# Job workspaces (runtime data)
/workspaces/
/jobs/
/local-workspaces/
**/local-workspaces/

# Docker volumes and containers
volumes/
.docker/

# Local development database snapshots
data/local/

# Generated reports and artifacts during job execution
artifacts/
# Exceptions for Next.js route directories
!apps/orchestrator-web/app/**/artifacts/
!apps/orchestrator-web/components/artifacts/
reports/
docs/_site/
docs/api/.manifest
docs/api/*.yml
docs/api/toc.yml
.playwright-mcp/

# Agent outputs
agent-output/
