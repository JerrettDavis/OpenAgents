# ─────────────────────────────────────────────────────────────────────
# OpenAgents – root environment template
# Copy to .env for local docker compose overrides.
# NEVER commit .env or any file containing real secrets.
#
# Quick start:
#   cp .env.example .env
#   # Edit .env and set the provider credentials you need
#   bash scripts/build-images.sh
#   docker compose up -d
# ─────────────────────────────────────────────────────────────────────

# ── SQLite / Orchestrator API ────────────────────────────────────────
DB_CONNECTION_STRING=Data Source=/data/openagents.db

ASPNETCORE_ENVIRONMENT=Development

# ── Web ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Provider credentials ──────────────────────────────────────────────
# Set whichever provider credentials you plan to use. These values are
# forwarded into provider containers at runtime and are NEVER baked into images.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GH_TOKEN=
GITHUB_TOKEN=

# ── Provider image refs (built by scripts/build-images.sh) ────────────
CLAUDE_CODE_IMAGE_REF=openagents/provider-claude-code:latest
OPENCODE_IMAGE_REF=openagents/provider-opencode:latest
CODEX_IMAGE_REF=openagents/provider-codex:latest
GEMINI_IMAGE_REF=openagents/provider-gemini:latest
COPILOT_IMAGE_REF=openagents/provider-copilot:latest
