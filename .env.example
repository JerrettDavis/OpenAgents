# ─────────────────────────────────────────────────────────────────────
# OpenAgents – root environment template
# Copy to .env for local docker compose overrides.
# NEVER commit .env or any file containing real secrets.
#
# Quick start:
#   cp .env.example .env
#   # Edit .env and set ANTHROPIC_API_KEY
#   docker compose up -d
# ─────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────
DB_CONNECTION_STRING=Host=postgres;Database=openagents;Username=openagents;Password=openagents
POSTGRES_PASSWORD=openagents

# ── Orchestrator API ──────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development

# ── Web ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Claude Code Provider (v1 only provider) ───────────────────────────
# REQUIRED for Claude Code jobs. Obtain at: https://console.anthropic.com
# This value is passed as an environment variable into agent containers
# at runtime. It is NEVER baked into any Docker image.
ANTHROPIC_API_KEY=

# Provider image ref (built by scripts/build-images.sh)
CLAUDE_CODE_IMAGE_REF=openagents/provider-claude-code:latest
